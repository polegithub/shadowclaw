{
  "$schema": "ShadowClaw snapshot path configuration",
  "$version": "2.0.0",
  "state_dir": "~/.openclaw",
  "critical": {
    "$comment": "丢失后无法恢复，必须备份",
    "files": [
      "openclaw.json",
      "agents/main/agent/auth-profiles.json",
      "agents/main/sessions/sessions.json",
      "credentials/oauth.json",
      "credentials/feishu-pairing.json",
      "credentials/whatsapp/default/creds.json",
      "memory/main.sqlite"
    ],
    "directories": [
      "memory/lancedb",
      "workspace"
    ]
  },
  "important": {
    "$comment": "丢失后可重建但耗时，建议备份",
    "files": [
      "agents/main/agent/models.json",
      "cron/jobs.json",
      "identity/device.json",
      "identity/device-auth.json",
      ".env"
    ],
    "directories": [
      "skills"
    ],
    "glob": [
      "agents/main/sessions/*.jsonl",
      "feishu/dedup/*.json",
      "devices/*.json"
    ]
  },
  "optional": {
    "$comment": "通常可以忽略或自动重建",
    "files": [
      "canvas/index.html"
    ]
  },
  "exclude": {
    "patterns": [
      "extensions/**",
      "logs/**",
      "completions/**",
      "delivery-queue/**",
      "sandboxes/**",
      "**/.git/**",
      "**/node_modules/**",
      "**/*.log",
      "**/*.tmp",
      "**/*.cache",
      "**/__pycache__/**",
      "openclaw.json.bak*",
      "*.lock",
      "snapshots/**",
      "workspace/.shadowclaw/**",
      "workspace/**/*.pyc"
    ]
  },
  "size_limits": {
    "default_max_mb": 10,
    "overrides": {
      "memory/main.sqlite": 100,
      "agents/main/sessions/*.jsonl": 50,
      "memory/lancedb/**": 100
    }
  },
  "desensitize": {
    "files": [
      "openclaw.json",
      "agents/main/agent/auth-profiles.json",
      "credentials/oauth.json",
      "credentials/feishu-pairing.json",
      "credentials/whatsapp/default/creds.json",
      "identity/device.json",
      "identity/device-auth.json",
      ".env"
    ],
    "glob_files": [
      "agents/main/sessions/*.jsonl"
    ],
    "json_patterns": [
      "token",
      "auth_token",
      "authToken",
      "api_key",
      "apiKey",
      "apikey",
      "secret",
      "appSecret",
      "app_secret",
      "password",
      "passwd",
      "private_key",
      "privateKey",
      "client_secret",
      "clientSecret",
      "access_token",
      "accessToken",
      "refresh_token",
      "refreshToken",
      "kimiCodeAPIKey",
      "kimiPluginAPIKey",
      "appId",
      "app_id",
      "webhook_secret",
      "signing_secret",
      "encryption_key",
      "encryptionKey",
      "bot_token",
      "botToken",
      "verification_token"
    ],
    "value_patterns": [
      "sk-[a-zA-Z0-9]{20,}",
      "ghp_[a-zA-Z0-9]{36}",
      "ghu_[a-zA-Z0-9]{36}",
      "ghs_[a-zA-Z0-9]{36}",
      "xoxb-[a-zA-Z0-9-]+",
      "xoxp-[a-zA-Z0-9-]+",
      "Bearer [a-zA-Z0-9._-]{20,}",
      "cli_[a-zA-Z0-9]{16,}",
      "ou_[a-zA-Z0-9]{32,}"
    ],
    "env_patterns": [
      "API_KEY=",
      "SECRET=",
      "TOKEN=",
      "PASSWORD=",
      "PRIVATE_KEY=",
      "ACCESS_KEY=",
      "AUTH_TOKEN=",
      "ENCRYPTION_KEY=",
      "WEBHOOK_SECRET="
    ]
  },
  "github": {
    "repo": "github.com/polegithub/shadowclaw",
    "branch": "main",
    "token_env": [
      "GH_TOKEN",
      "GITHUB_TOKEN"
    ]
  }
}
