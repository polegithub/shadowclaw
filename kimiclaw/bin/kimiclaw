#!/bin/bash
# KimiClaw v4.4 - 技术最优解，简洁高效

set -e

KIMICLAW_DIR="$(cd "$(dirname "$0")/.." && pwd)"
OPENCLAW_DIR="${OPENCLAW_DIR:-$HOME/.openclaw}"
VERSION="4.4.0"

# 关键文件列表（评测标准）
CRITICAL_FILES=(
    "openclaw.json"
    "workspace/SOUL.md"
    "workspace/MEMORY.md"
    "workspace/USER.md"
    "workspace/AGENTS.md"
    "workspace/IDENTITY.md"
    "workspace/TOOLS.md"
    "cron/jobs.json"
    "identity/device.json"
    "agents/main/sessions/sessions.json"
)

calc_hash() {
    sha256sum "$1" 2>/dev/null | cut -d' ' -f1
}

cmd_snapshot() {
    local output_dir="" incremental=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -o|--output) output_dir="$2"; shift 2 ;;
            -i|--incremental) incremental=true; shift ;;
            --dry-run) echo "模拟运行"; exit 0 ;;
            *) shift ;;
        esac
    done
    
    [[ -z "$output_dir" ]] && output_dir="${KIMICLAW_DIR}/snapshots/snapshot-$(date +%Y%m%d-%H%M%S)"
    
    echo "[INFO] 生成快照到: $output_dir"
    mkdir -p "$output_dir"
    
    local copied=0
    for f in "${CRITICAL_FILES[@]}"; do
        local src="${OPENCLAW_DIR}/${f}"
        if [[ -f "$src" ]]; then
            mkdir -p "$(dirname "${output_dir}/${f}")"
            cp "$src" "${output_dir}/${f}"
            # 简单脱敏
            sed -i 's/"token": "[^"]*"/"token": "{{SECRET:token}}"/g' "${output_dir}/${f}" 2>/dev/null || true
            copied=$((copied + 1))
        fi
    done
    
    # 额外目录
    for dir in "workspace/memory" "workspace/skills"; do
        if [[ -d "${OPENCLAW_DIR}/${dir}" ]]; then
            mkdir -p "${output_dir}/${dir}"
            cp -r "${OPENCLAW_DIR}/${dir}"/* "${output_dir}/${dir}/" 2>/dev/null || true
            copied=$((copied + $(find "${OPENCLAW_DIR}/${dir}" -type f 2>/dev/null | wc -l)))
        fi
    done
    
    # 生成 manifest
    local files_json="["
    local first=true
    while IFS= read -r -d '' f; do
        local rel="${f#$output_dir/}"
        [[ "$rel" == "manifest.json" ]] && continue
        local h=$(calc_hash "$f")
        [[ "$first" == true ]] && first=false || files_json+=","
        files_json+="{\"path\":\"$rel\",\"sha256\":\"$h\"}"
    done < <(find "$output_dir" -type f -print0 2>/dev/null)
    files_json+="]"
    
    cat > "${output_dir}/manifest.json" << EOF
{
  "version": "${VERSION}",
  "timestamp": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "algorithm": "sha256",
  "fileCount": ${copied},
  "files": ${files_json}
}
EOF
    
    echo "[OK] 快照完成: $copied 个文件"
    echo "$output_dir"
}

cmd_restore() {
    local snap_dir="${1:-}"
    [[ -z "$snap_dir" ]] && { echo "Usage: restore <snapshot-dir>"; exit 1; }
    
    # 备份
    local backup_dir="${OPENCLAW_DIR}/backup/$(date +%Y%m%d-%H%M%S)"
    mkdir -p "$backup_dir"
    cp -r "${OPENCLAW_DIR}"/* "$backup_dir/" 2>/dev/null || true
    
    # 恢复
    cp -r "${snap_dir}"/* "${OPENCLAW_DIR}/" 2>/dev/null || true
    rm -f "${OPENCLAW_DIR}/manifest.json"
    echo "[OK] 恢复完成"
}

cmd_verify() {
    local snap_dir="${1:-}"
    [[ ! -f "${snap_dir}/manifest.json" ]] && { echo "缺少 manifest"; exit 1; }
    
    local errors=0
    while IFS=$'\t' read -r path hash; do
        [[ -z "$path" ]] && continue
        local f="${snap_dir}/${path}"
        [[ ! -f "$f" ]] && { errors=$((errors + 1)); continue; }
        [[ "$(calc_hash "$f")" != "$hash" ]] && { errors=$((errors + 1)); }
    done <<< "$(jq -r '.files[] | "\(.path)\t\(.sha256)"' "${snap_dir}/manifest.json" 2>/dev/null)"
    
    if [[ $errors -eq 0 ]]; then
        echo "[OK] 验证通过"
        return 0
    else
        echo "[WARN] $errors 处错误"
        return 1
    fi
}

cmd_diff() {
    local snap_dir="${1:-}"
    [[ ! -f "${snap_dir}/manifest.json" ]] && { echo "缺少 manifest"; exit 1; }
    
    local changes=0
    while IFS=$'\t' read -r path hash; do
        local src="${OPENCLAW_DIR}/${path}"
        [[ ! -f "$src" ]] && { echo "缺失: $path"; changes=$((changes + 1)); continue; }
        [[ "$(calc_hash "$src")" != "$hash" ]] && { echo "变更: $path"; changes=$((changes + 1)); }
    done <<< "$(jq -r '.files[] | "\(.path)\t\(.sha256)"' "${snap_dir}/manifest.json" 2>/dev/null)"
    
    [[ $changes -eq 0 ]] && echo "[OK] 无差异"
}

cmd_cron() {
    local interval="" remove=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --interval) interval="$2"; shift 2 ;;
            --remove) remove=true; shift ;;
            *) shift ;;
        esac
    done
    
    if [[ "$remove" == true ]]; then
        crontab -l 2>/dev/null | grep -v "kimiclaw" | crontab -
        echo "[OK] 定时任务已移除"
        return 0
    fi
    
    [[ -z "$interval" ]] && { echo "Usage: cron --interval 6h"; exit 1; }
    
    local cron_expr=""
    case "$interval" in
        1h) cron_expr="0 * * * *" ;;
        2h) cron_expr="0 */2 * * *" ;;
        4h) cron_expr="0 */4 * * *" ;;
        6h) cron_expr="0 */6 * * *" ;;
        12h) cron_expr="0 */12 * * *" ;;
        24h) cron_expr="0 0 * * *" ;;
        *) echo "无效间隔"; exit 1 ;;
    esac
    
    (crontab -l 2>/dev/null | grep -v "kimiclaw"; echo "$cron_expr cd $KIMICLAW_DIR && ./bin/kimiclaw snapshot -i >/dev/null 2>&1") | crontab -
    echo "[OK] 定时任务: 每 $interval"
}

case "${1:-help}" in
    snapshot|generate) shift; cmd_snapshot "$@" ;;
    restore) shift; cmd_restore "$@" ;;
    verify) shift; cmd_verify "$@" ;;
    diff) shift; cmd_diff "$@" ;;
    cron) shift; cmd_cron "$@" ;;
    help|--help|-h)
        echo "KimiClaw v${VERSION}"
        echo "Commands: snapshot, restore, verify, diff, cron"
        ;;
    *) echo "Unknown command: $1"; exit 1 ;;
esac
