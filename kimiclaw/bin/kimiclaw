#!/bin/bash
#
# KimiClaw v4.0 - OpenClaw 快照管理工具
# 配置驱动、简洁高效
#

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
KIMICLAW_DIR="$(dirname "$SCRIPT_DIR")"
CONFIG_FILE="${KIMICLAW_DIR}/config/default.json"
OPENCLAW_DIR="${OPENCLAW_DIR:-$HOME/.openclaw}"
VERSION="4.1.0"

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# 打印帮助信息
show_help() {
    cat << EOF
KimiClaw v${VERSION} - OpenClaw 环境快照管理工具

用法:
    kimiclaw <command> [options]

命令:
    generate, g     生成快照
    restore, r      恢复快照
    auto-restore    一键恢复（自动填入凭证）
    setup           交互式配置凭证
    push, p         推送到远程仓库
    pull, pl        从远程拉取
    list, ls        列出本地快照
    clean           清理旧快照
    verify          验证快照完整性
    test            运行恢复测试
    config          显示配置
    help            显示帮助

generate 选项:
    -o, --output    指定输出目录
    -d, --dry-run   模拟运行（不实际执行）
    -f, --force     强制覆盖

restore 选项:
    -f, --force     强制恢复（跳过确认）
    -b, --backup    恢复前备份当前环境

push 选项:
    -r, --repo      指定仓库
    -b, --branch    指定分支
    -m, --message   提交信息

示例:
    kimiclaw generate                    # 生成快照到默认目录
    kimiclaw generate -o ./my-snapshot   # 指定输出目录
    kimiclaw restore ./snapshot-xxx      # 恢复快照
    kimiclaw push                        # 推送到默认仓库
    kimiclaw list                        # 列出快照
    kimiclaw clean -k 5                  # 保留最近5个快照

EOF
}

# 日志函数
log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}[OK]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }

# 检查依赖
check_deps() {
    local deps=("jq" "git" "rsync")
    for dep in "${deps[@]}"; do
        if ! command -v "$dep" >/dev/null 2>&1; then
            log_error "缺少依赖: $dep"
            exit 1
        fi
    done
}

# 生成快照
cmd_generate() {
    local output_dir=""
    local dry_run=false
    local force=false
    
    # 解析参数
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -o|--output) output_dir="$2"; shift 2 ;;
            -d|--dry-run) dry_run=true; shift ;;
            -f|--force) force=true; shift ;;
            *) shift ;;
        esac
    done
    
    # 默认输出目录
    if [[ -z "$output_dir" ]]; then
        local timestamp=$(date +%Y%m%d-%H%M%S)
        output_dir="${KIMICLAW_DIR}/snapshots/snapshot-${timestamp}"
    fi
    
    log_info "开始生成快照..."
    log_info "源目录: $OPENCLAW_DIR"
    log_info "目标目录: $output_dir"
    
    if [[ "$dry_run" == true ]]; then
        log_warn "模拟运行模式，不实际执行"
    fi
    
    # 检查源目录
    if [[ ! -d "$OPENCLAW_DIR" ]]; then
        log_error "OpenClaw 目录不存在: $OPENCLAW_DIR"
        exit 1
    fi
    
    # 创建目标目录
    if [[ "$dry_run" == false ]]; then
        mkdir -p "$output_dir"
    fi
    
    # 优先级路径列表
    local critical_paths=(
        "openclaw.json"
        "agents/main/agent/auth-profiles.json"
        "agents/main/sessions/sessions.json"
        "credentials/oauth.json"
        "credentials/feishu-pairing.json"
        "credentials/whatsapp/default/creds.json"
        "memory/main.sqlite"
        "workspace/AGENTS.md"
        "workspace/SOUL.md"
        "workspace/USER.md"
        "workspace/IDENTITY.md"
        "workspace/MEMORY.md"
    )
    
    local important_paths=(
        ".env"
        "agents/main/agent/models.json"
        "agents/main/sessions/*.jsonl"
        "workspace/TOOLS.md"
        "workspace/HEARTBEAT.md"
        "workspace/skills"
        "cron/jobs.json"
        "identity/device.json"
        "identity/device-auth.json"
    )
    
    local copied_count=0
    local skipped_count=0
    
    # 复制必备文件
    log_info "复制 ⭐⭐⭐ 必备文件..."
    for path in "${critical_paths[@]}"; do
        local src="${OPENCLAW_DIR}/${path}"
        if [[ -e "$src" ]]; then
            local dest="${output_dir}/${path}"
            if [[ "$dry_run" == false ]]; then
                mkdir -p "$(dirname "$dest")"
                if [[ -f "$src" ]]; then
                    cp "$src" "$dest"
                    # 脱敏处理
                    sanitize_file "$dest"
                elif [[ -d "$src" ]]; then
                    cp -r "$src" "$dest"
                fi
            fi
            log_success "  ✓ $path"
            ((copied_count++))
        else
            log_warn "  ✗ $path (不存在)"
            ((skipped_count++))
        fi
    done
    
    # 复制重要文件
    log_info "复制 ⭐⭐ 重要文件..."
    for path in "${important_paths[@]}"; do
        local src="${OPENCLAW_DIR}/${path}"
        if [[ -e "$src" ]]; then
            local dest="${output_dir}/${path}"
            if [[ "$dry_run" == false ]]; then
                mkdir -p "$(dirname "$dest")"
                cp -r "$src" "$dest"
            fi
            log_success "  ✓ $path"
            ((copied_count++))
        else
            log_warn "  ✗ $path (不存在)"
            ((skipped_count++))
        fi
    done
    
    # 生成 manifest
    if [[ "$dry_run" == false ]]; then
        generate_manifest "$output_dir" "$copied_count"
        generate_secrets_template "$output_dir"
    fi
    
    log_success "快照生成完成!"
    log_info "文件统计: $copied_count 已复制, $skipped_count 已跳过"
    
    if [[ "$dry_run" == false ]]; then
        log_info "快照位置: $output_dir"
        echo "$output_dir"
    fi
}

# 脱敏处理
sanitize_file() {
    local file="$1"
    local sensitive_fields=("token" "apiKey" "api_key" "secret" "password" "privateKey" "client_secret" "access_token" "refresh_token")
    
    for field in "${sensitive_fields[@]}"; do
        if [[ -f "$file" ]]; then
            # 使用 sed 脱敏 JSON 中的敏感字段
            sed -i -E "s/(\"$field\":[[:space:]]*\")([^\"]+)(\")/\1{{SECRET:$field}}\3/g" "$file" 2>/dev/null || true
        fi
    done
}

# 生成 manifest
generate_manifest() {
    local snapshot_dir="$1"
    local file_count="$2"
    local timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    local hostname=$(hostname)
    
    cat > "${snapshot_dir}/manifest.json" << EOF
{
  "version": "${VERSION}",
  "timestamp": "${timestamp}",
  "hostname": "${hostname}",
  "generatedBy": "kimiclaw",
  "fileCount": ${file_count},
  "contents": {
    "openclaw.json": $(test -f "${snapshot_dir}/openclaw.json" && echo "true" || echo "false"),
    "authProfiles": $(test -f "${snapshot_dir}/agents/main/agent/auth-profiles.json" && echo "true" || echo "false"),
    "sessions": $(test -f "${snapshot_dir}/agents/main/sessions/sessions.json" && echo "true" || echo "false"),
    "credentials": $(test -d "${snapshot_dir}/credentials" && echo "true" || echo "false"),
    "memory": $(test -f "${snapshot_dir}/memory/main.sqlite" && echo "true" || echo "false"),
    "workspace": $(test -d "${snapshot_dir}/workspace" && echo "true" || echo "false"),
    "skills": $(test -d "${snapshot_dir}/skills" && echo "true" || echo "false"),
    "cron": $(test -f "${snapshot_dir}/cron/jobs.json" && echo "true" || echo "false"),
    "identity": $(test -d "${snapshot_dir}/identity" && echo "true" || echo "false")
  }
}
EOF
}

# 生成凭证模板
generate_secrets_template() {
    local snapshot_dir="$1"
    
    cat > "${snapshot_dir}/secrets-template.json" << 'EOF'
{
  "_comment": "恢复环境时，请填入真实凭证替换 {{SECRET:xxx}} 占位符",
  "credentials": {
    "oauth": {
      "token": "your_token_here"
    },
    "feishu": {
      "appId": "your_app_id",
      "appSecret": "your_app_secret"
    },
    "whatsapp": {
      "creds": "your_whatsapp_credentials"
    }
  },
  "agents": {
    "authProfiles": {
      "openai": "sk-your-api-key",
      "anthropic": "sk-ant-your-api-key"
    }
  }
}
EOF
}

# 恢复快照
cmd_restore() {
    local snapshot_dir="$1"
    local force=false
    local backup=true
    
    # 解析参数
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -f|--force) force=true; shift ;;
            -b|--backup) backup=true; shift ;;
            --no-backup) backup=false; shift ;;
            -*) shift ;;
            *) snapshot_dir="$1"; shift ;;
        esac
    done
    
    # 检查快照目录
    if [[ -z "$snapshot_dir" ]] || [[ ! -d "$snapshot_dir" ]]; then
        log_error "请指定有效的快照目录"
        log_info "用法: kimiclaw restore <snapshot-dir>"
        exit 1
    fi
    
    # 检查 manifest
    if [[ ! -f "${snapshot_dir}/manifest.json" ]]; then
        log_warn "快照缺少 manifest.json，可能不完整"
        if [[ "$force" != true ]]; then
            read -p "是否继续? [y/N] " -n 1 -r
            echo
            if [[ ! $REPLY =~ ^[Yy]$ ]]; then
                exit 1
            fi
        fi
    fi
    
    log_info "准备恢复快照: $snapshot_dir"
    log_info "目标目录: $OPENCLAW_DIR"
    
    # 备份当前环境
    if [[ "$backup" == true ]]; then
        local backup_dir="${OPENCLAW_DIR}/backup/$(date +%Y%m%d-%H%M%S)"
        log_info "备份当前环境到: $backup_dir"
        mkdir -p "$backup_dir"
        rsync -a --exclude='backup' --exclude='snapshots' "$OPENCLAW_DIR/" "$backup_dir/" 2>/dev/null || true
    fi
    
    # 确认恢复
    if [[ "$force" != true ]]; then
        echo
        log_warn "⚠️  这将覆盖当前 OpenClaw 环境!"
        read -p "是否继续? [y/N] " -n 1 -r
        echo
        if [[ ! $REPLY =~ ^[Yy]$ ]]; then
            log_info "已取消恢复"
            exit 0
        fi
    fi
    
    # 执行恢复
    log_info "开始恢复文件..."
    rsync -av --exclude='manifest.json' --exclude='secrets-template.json' "${snapshot_dir}/" "$OPENCLAW_DIR/"
    
    log_success "恢复完成!"
    log_info "请检查 ${snapshot_dir}/secrets-template.json 填入真实凭证"
    log_info "然后重启 OpenClaw: openclaw gateway restart"
}

# 推送到远程
cmd_push() {
    local repo=""
    local branch="main"
    local message="KimiClaw 快照更新: $(date +%Y-%m-%d\ %H:%M)"
    
    # 解析参数
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -r|--repo) repo="$2"; shift 2 ;;
            -b|--branch) branch="$2"; shift 2 ;;
            -m|--message) message="$2"; shift 2 ;;
            *) shift ;;
        esac
    done
    
    # 从配置读取默认仓库
    if [[ -z "$repo" ]] && [[ -f "$CONFIG_FILE" ]]; then
        repo=$(jq -r '.github.repo // empty' "$CONFIG_FILE" 2>/dev/null)
    fi
    
    if [[ -z "$repo" ]]; then
        log_error "未指定仓库，请使用 -r 参数或配置 github.repo"
        exit 1
    fi
    
    log_info "推送到仓库: $repo (分支: $branch)"
    
    # 检查 git
    if [[ ! -d "${KIMICLAW_DIR}/.git" ]]; then
        log_info "初始化 git 仓库..."
        cd "$KIMICLAW_DIR"
        git init
        git remote add origin "https://${repo}.git" 2>/dev/null || true
    fi
    
    cd "$KIMICLAW_DIR"
    
    # 添加并提交
    git add -A
    if git diff --cached --quiet; then
        log_info "没有变更需要提交"
        return 0
    fi
    
    git commit -m "$message"
    
    # 推送
    if git push origin "HEAD:${branch}" 2>/dev/null; then
        log_success "推送成功!"
    else
        log_error "推送失败，请检查网络或权限"
        exit 1
    fi
}

# 从远程拉取
cmd_pull() {
    local branch="main"
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -b|--branch) branch="$2"; shift 2 ;;
            *) shift ;;
        esac
    done
    
    log_info "从远程拉取更新 (分支: $branch)..."
    
    cd "$KIMICLAW_DIR"
    git pull origin "$branch"
    
    log_success "拉取完成!"
}

# 列出快照
cmd_list() {
    local snapshots_dir="${KIMICLAW_DIR}/snapshots"
    
    if [[ ! -d "$snapshots_dir" ]]; then
        log_info "没有本地快照"
        return 0
    fi
    
    log_info "本地快照列表:"
    echo
    
    local count=0
    for snapshot in "${snapshots_dir}"/snapshot-*; do
        if [[ -d "$snapshot" ]]; then
            local name=$(basename "$snapshot")
            local size=$(du -sh "$snapshot" 2>/dev/null | cut -f1)
            local date=$(stat -c %y "$snapshot" 2>/dev/null | cut -d' ' -f1)
            printf "  %-30s %8s  %s\n" "$name" "$size" "$date"
            ((count++))
        fi
    done
    
    echo
    log_info "总计: $count 个快照"
}

# 清理旧快照
cmd_clean() {
    local keep_count=5
    local dry_run=false
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -k|--keep) keep_count="$2"; shift 2 ;;
            -d|--dry-run) dry_run=true; shift ;;
            *) shift ;;
        esac
    done
    
    local snapshots_dir="${KIMICLAW_DIR}/snapshots"
    
    if [[ ! -d "$snapshots_dir" ]]; then
        log_info "没有需要清理的快照"
        return 0
    fi
    
    # 获取快照列表，按时间排序
    local snapshots=($(ls -1td "${snapshots_dir}"/snapshot-* 2>/dev/null || true))
    local total_count=${#snapshots[@]}
    
    if [[ $total_count -le $keep_count ]]; then
        log_info "快照数量 ($total_count) 未超过保留数量 ($keep_count)，无需清理"
        return 0
    fi
    
    log_info "保留最近 $keep_count 个快照，删除其余 $((total_count - keep_count)) 个..."
    
    for ((i=keep_count; i<total_count; i++)); do
        local snapshot="${snapshots[$i]}"
        local name=$(basename "$snapshot")
        
        if [[ "$dry_run" == true ]]; then
            log_info "[模拟] 将删除: $name"
        else
            rm -rf "$snapshot"
            log_success "已删除: $name"
        fi
    done
    
    log_success "清理完成!"
}

# 验证快照
cmd_verify() {
    local snapshot_dir="$1"
    
    if [[ -z "$snapshot_dir" ]]; then
        log_error "请指定快照目录"
        exit 1
    fi
    
    if [[ ! -d "$snapshot_dir" ]]; then
        log_error "快照目录不存在: $snapshot_dir"
        exit 1
    fi
    
    log_info "验证快照: $snapshot_dir"
    echo
    
    local has_error=false
    
    # 检查 manifest
    if [[ ! -f "${snapshot_dir}/manifest.json" ]]; then
        log_warn "⚠️  缺少 manifest.json"
        has_error=true
    else
        log_success "✓ manifest.json 存在"
    fi
    
    # 检查关键文件
    local critical_files=(
        "openclaw.json"
        "agents/main/agent/auth-profiles.json"
        "workspace/AGENTS.md"
        "workspace/SOUL.md"
    )
    
    echo
    log_info "必备文件检查:"
    for file in "${critical_files[@]}"; do
        if [[ -e "${snapshot_dir}/${file}" ]]; then
            log_success "  ✓ $file"
        else
            log_warn "  ✗ $file (缺失)"
        fi
    done
    
    # 检查脱敏
    echo
    log_info "安全检查:"
    if grep -r "sk-" "${snapshot_dir}" --include="*.json" 2>/dev/null | grep -v "{{SECRET:" >/dev/null; then
        log_warn "⚠️  发现可能的未脱敏 API Key"
        has_error=true
    else
        log_success "✓ 未发现明显的凭证泄露"
    fi
    
    echo
    if [[ "$has_error" == true ]]; then
        log_warn "验证发现问题，建议重新生成快照"
        return 1
    else
        log_success "验证通过!"
        return 0
    fi
}

# 显示配置
cmd_config() {
    log_info "KimiClaw 配置信息:"
    echo
    echo "版本:     $VERSION"
    echo "配置文件: $CONFIG_FILE"
    echo "OpenClaw: $OPENCLAW_DIR"
    echo
    
    if [[ -f "$CONFIG_FILE" ]]; then
        log_info "配置文件内容:"
        cat "$CONFIG_FILE" | jq .
    else
        log_warn "配置文件不存在"
    fi
}

# 一键恢复（自动填入凭证）
cmd_auto_restore() {
    local snapshot_dir="$1"
    local force=false
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -f|--force) force=true; shift ;;
            -*) shift ;;
            *) snapshot_dir="$1"; shift ;;
        esac
    done
    
    if [[ -z "$snapshot_dir" ]] || [[ ! -d "$snapshot_dir" ]]; then
        log_error "请指定有效的快照目录"
        exit 1
    fi
    
    log_info "开始一键恢复..."
    
    # 先执行普通恢复（不提示）
    cmd_restore "$snapshot_dir" --no-backup
    
    # 检查是否有本地凭证备份
    local creds_backup="${OPENCLAW_DIR}/.credentials_backup.json"
    if [[ -f "$creds_backup" ]]; then
        log_info "发现本地凭证备份，自动恢复凭证..."
        restore_credentials_from_backup "$creds_backup"
    else
        log_warn "未找到本地凭证备份"
        log_info "请运行: kimiclaw setup 配置凭证"
    fi
    
    log_success "一键恢复完成!"
    log_info "建议重启 OpenClaw: openclaw gateway restart"
}

# 从备份恢复凭证
restore_credentials_from_backup() {
    local backup_file="$1"
    
    # 读取备份的凭证并填入
    local openai_key=$(jq -r '.agents.authProfiles.openai // empty' "$backup_file" 2>/dev/null)
    if [[ -n "$openai_key" ]] && [[ "$openai_key" != "null" ]]; then
        sed -i "s/{{SECRET:apiKey}}/$openai_key/g" "${OPENCLAW_DIR}/agents/main/agent/auth-profiles.json" 2>/dev/null || true
        log_success "  ✓ 恢复 OpenAI API Key"
    fi
}

# 交互式配置凭证
cmd_setup() {
    log_info "KimiClaw 交互式配置"
    echo
    
    local creds_file="${OPENCLAW_DIR}/.credentials_backup.json"
    
    read -p "OpenAI API Key: " openai_key
    read -p "Anthropic API Key: " anthropic_key
    read -p "Feishu App ID: " feishu_appid
    read -p "Feishu App Secret: " feishu_secret
    
    # 保存到备份文件
    cat > "$creds_file" << EOF
{
  "agents": {
    "authProfiles": {
      "openai": "$openai_key",
      "anthropic": "$anthropic_key"
    }
  },
  "credentials": {
    "feishu": {
      "appId": "$feishu_appid",
      "appSecret": "$feishu_secret"
    }
  },
  "updatedAt": "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
}
EOF
    
    chmod 600 "$creds_file"
    log_success "凭证已保存到: $creds_file"
    log_info "下次恢复时会自动填入这些凭证"
}

# 运行恢复测试
cmd_test() {
    log_info "运行 KimiClaw 恢复测试..."
    echo
    
    local test_dir="${KIMICLAW_DIR}/test_snapshot"
    local errors=0
    
    # 测试1: 生成快照
    log_info "测试1: 生成快照..."
    local snapshot_path=$(cmd_generate -o "$test_dir" 2>/dev/null)
    if [[ -d "$snapshot_path" ]]; then
        log_success "✓ 快照生成成功"
    else
        log_error "✗ 快照生成失败"
        ((errors++))
    fi
    
    # 测试2: 验证快照
    log_info "测试2: 验证快照..."
    if cmd_verify "$snapshot_path" >/dev/null 2>&1; then
        log_success "✓ 快照验证通过"
    else
        log_warn "  快照验证有警告"
    fi
    
    # 测试3: 检查体积
    log_info "测试3: 检查快照体积..."
    local size=$(du -sm "$snapshot_path" 2>/dev/null | cut -f1)
    if [[ $size -lt 100 ]]; then
        log_success "✓ 快照体积: ${size}MB (< 100MB)"
    else
        log_warn "  快照体积较大: ${size}MB"
    fi
    
    # 清理测试快照
    rm -rf "$test_dir"
    
    echo
    if [[ $errors -eq 0 ]]; then
        log_success "所有测试通过!"
        return 0
    else
        log_error "测试失败: $errors 个错误"
        return 1
    fi
}

# 主入口
main() {
    # 检查依赖
    check_deps
    
    # 解析命令
    local cmd="${1:-help}"
    shift || true
    
    case "$cmd" in
        generate|g) cmd_generate "$@" ;;
        restore|r) cmd_restore "$@" ;;
        auto-restore) cmd_auto_restore "$@" ;;
        setup) cmd_setup "$@" ;;
        push|p) cmd_push "$@" ;;
        pull|pl) cmd_pull "$@" ;;
        list|ls) cmd_list "$@" ;;
        clean) cmd_clean "$@" ;;
        verify) cmd_verify "$@" ;;
        test) cmd_test "$@" ;;
        config) cmd_config "$@" ;;
        help|--help|-h) show_help ;;
        *) 
            log_error "未知命令: $cmd"
            show_help
            exit 1
            ;;
    esac
}

main "$@"
