#!/bin/bash
# snapshot-push: 推送快照到远程仓库

set -e

SNAPSHOT_DIR="$1"
REPO_URL="${2:-}"
BRANCH="${3:-main}"

# 如果没有指定快照目录，使用最新的
if [ -z "$SNAPSHOT_DIR" ] || [ ! -d "$SNAPSHOT_DIR" ]; then
    SNAPSHOT_DIR=$(find "${HOME}/.openclaw/snapshots" -type d -name "snapshot-*" | sort | tail -1)
    if [ -z "$SNAPSHOT_DIR" ]; then
        echo "❌ 错误: 未找到快照目录"
        echo "用法: snapshot-push [快照目录] [仓库地址] [分支]"
        exit 1
    fi
fi

echo "📤 推送快照到仓库"
echo "=================="
echo "快照目录: $SNAPSHOT_DIR"
echo ""

# 读取配置
CONFIG_FILE="${HOME}/.openclaw/snapshot-sync.json"
if [ -f "$CONFIG_FILE" ]; then
    REPO_URL="${REPO_URL:-$(cat "$CONFIG_FILE" | jq -r '.github.repo // empty')}"
    TOKEN="$(cat "$CONFIG_FILE" | jq -r '.github.token // empty')"
fi

# 检查仓库地址
if [ -z "$REPO_URL" ]; then
    echo "❌ 错误: 未指定仓库地址"
    echo ""
    echo "请在 ~/.openclaw/snapshot-sync.json 中配置:"
    echo '{'
    echo '  "github": {'
    echo '    "repo": "github.com/username/repo",'
    echo '    "branch": "main",'
    echo '    "token": "ghp_xxxxxxx"'
    echo '  }'
    echo '}'
    exit 1
fi

# 处理仓库 URL
if [[ "$REPO_URL" == github.com/* ]]; then
    REPO_PATH="${REPO_URL#github.com/}"
    if [ -n "$TOKEN" ]; then
        REMOTE_URL="https://${TOKEN}@github.com/${REPO_PATH}.git"
    else
        REMOTE_URL="https://github.com/${REPO_PATH}.git"
    fi
elif [[ "$REPO_URL" == http* ]]; then
    REMOTE_URL="$REPO_URL"
else
    REMOTE_URL="https://github.com/${REPO_URL}.git"
fi

echo "仓库: $REPO_URL"
echo "分支: $BRANCH"
echo ""

# 创建临时目录进行 git 操作
TEMP_DIR=$(mktemp -d)
trap "rm -rf $TEMP_DIR" EXIT

echo "🔄 准备推送..."

# 克隆仓库或初始化
cd "$TEMP_DIR"

if git clone --depth 1 --branch "$BRANCH" "$REMOTE_URL" . 2>/dev/null; then
    echo "✓ 已拉取现有分支: $BRANCH"
else
    echo "📝 初始化新仓库..."
    git init
    git remote add origin "$REMOTE_URL"
    git checkout -b "$BRANCH"
fi

# 清理旧快照文件（保留 .git 和其他重要文件）
find . -maxdepth 1 -type d ! -name ".git" ! -name "." -exec rm -rf {} + 2>/dev/null || true
find . -maxdepth 1 -type f ! -name ".gitignore" -delete 2>/dev/null || true

# 复制新快照内容
cp -r "$SNAPSHOT_DIR"/* .

# 创建 .gitignore
cat > .gitignore << 'EOF'
# OpenClaw Snapshot - 忽略文件
*.log
*.tmp
*.cache
.DS_Store
node_modules/
__pycache__/
.git/
EOF

# 提交并推送
echo ""
echo "📦 提交变更..."

git add -A
git commit -m "OpenClaw snapshot: $(date '+%Y-%m-%d %H:%M:%S')

- Skills: $(jq -r '.stats.skills_count // 0' manifest.json 2>/dev/null || echo 0)
- Memory files: $(jq -r '.stats.memory_files // 0' manifest.json 2>/dev/null || echo 0)
- Total size: $(jq -r '.stats.total_size_mb // 0' manifest.json 2>/dev/null || echo 0) MB

Generated by snapshot-sync v2.0.0" || {
    echo "✓ 没有变更需要提交"
    exit 0
}

echo "📤 推送到远程..."
if git push origin "$BRANCH" --force-with-lease 2>&1; then
    echo ""
    echo "✅ 推送成功！"
    echo ""
    echo "📎 访问链接:"
    if [[ "$REPO_URL" == github.com/* ]]; then
        echo "   https://github.com/${REPO_PATH}/tree/${BRANCH}"
    else
        echo "   $REMOTE_URL"
    fi
else
    echo ""
    echo "❌ 推送失败"
    echo ""
    echo "可能的原因："
    echo "   • Token 没有写入权限"
    echo "   • 仓库不存在"
    echo "   • 网络问题"
    echo ""
    echo "请检查配置: ~/.openclaw/snapshot-sync.json"
    exit 1
fi
