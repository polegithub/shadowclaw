#!/bin/bash
# snapshot-sync: OpenClaw 环境快照管理主入口

set -e

VERSION="2.0.0"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# 显示帮助
show_help() {
    cat << EOF
OpenClaw Snapshot Sync v${VERSION}

用法: snapshot-sync <命令> [选项]

命令:
  generate              生成当前环境快照
    选项:
      --output, -o      指定输出目录
      --max-size, -s    文件大小限制 (MB, 默认 10)
      --exclude, -e     排除模式 (逗号分隔)

  push [快照目录]       推送快照到远程仓库
    选项:
      --repo, -r        仓库地址
      --branch, -b      分支 (默认 main)
      --token, -t       GitHub Token

  pull                  从远程仓库拉取快照
    选项:
      --repo, -r        仓库地址
      --branch, -b      分支 (默认 main)
      --preview         仅预览，不恢复

  restore [快照目录]    恢复快照到当前环境
    选项:
      --merge, -m       智能合并模式 (保留本地备份)
      --only            仅恢复指定组件 (skills,memory,workspace,config)

  bootstrap             显示自举指南 (新 OpenClaw 实例)

  config                编辑配置文件

  list                  列出本地快照

  help                  显示此帮助信息

示例:
  snapshot-sync generate --max-size 5MB
  snapshot-sync push ./snapshot-xxx --repo github.com/user/repo
  snapshot-sync pull --repo github.com/user/repo --branch dev
  snapshot-sync restore --merge --only skills,memory

配置文件:
  ~/.openclaw/snapshot-sync.json

EOF
}

# 列出本地快照
list_snapshots() {
    local SNAPSHOTS_DIR="${HOME}/.openclaw/snapshots"
    
    echo "📂 本地快照列表"
    echo "=============="
    
    if [ ! -d "$SNAPSHOTS_DIR" ]; then
        echo "暂无快照"
        return
    fi
    
    local count=0
    for dir in "$SNAPSHOTS_DIR"/*; do
        if [ -d "$dir" ]; then
            local name=$(basename "$dir")
            local size=$(du -sh "$dir" 2>/dev/null | cut -f1)
            local date=$(echo "$name" | grep -oE '[0-9]{8}-[0-9]{6}' || echo "unknown")
            
            if [ -f "$dir/manifest.json" ]; then
                local skills=$(jq -r '.stats.skills_count // 0' "$dir/manifest.json" 2>/dev/null)
                echo "  • $name"
                echo "    时间: $date | 大小: $size | Skills: $skills"
            else
                echo "  • $name (旧格式)"
            fi
            ((count++))
            echo ""
        fi
    done
    
    if [ $count -eq 0 ]; then
        echo "暂无快照"
    else
        echo "共 $count 个快照"
    fi
}

# 显示自举指南
show_bootstrap() {
    cat << 'EOF'
🚀 OpenClaw Snapshot Sync - 自举指南
====================================

欢迎来到新的 OpenClaw 实例！

如果你是第一次看到这条消息，说明 snapshot-sync skill 已经成功安装。

## 快速开始

### 1. 拉取已有快照

如果你有之前备份的快照：

   snapshot-sync pull --repo github.com/username/repo --branch main

### 2. 恢复环境

   snapshot-sync restore

### 3. 填入凭证

   编辑 ~/.openclaw/secrets-template.json
   填入真实值后保存为 ~/.openclaw/secrets.json

### 4. 重启 OpenClaw

   openclaw gateway restart

## 创建新快照

如果你想备份当前环境：

   snapshot-sync generate
   snapshot-sync push

## 更多信息

   snapshot-sync help
   cat ~/.openclaw/workspace/skills/snapshot-sync/SKILL.md

EOF
}

# 解析参数
COMMAND="${1:-help}"
shift || true

# 根据命令执行
case "$COMMAND" in
    generate|gen|g)
        exec "$SCRIPT_DIR/snapshot-generate" "$@"
        ;;
    
    push|p)
        exec "$SCRIPT_DIR/snapshot-push" "$@"
        ;;
    
    pull|clone)
        exec "$SCRIPT_DIR/snapshot-pull" "$@"
        ;;
    
    restore|r)
        exec "$SCRIPT_DIR/snapshot-restore" "$@"
        ;;
    
    bootstrap|boot)
        show_bootstrap
        ;;
    
    config|cfg)
        ${EDITOR:-nano} "${HOME}/.openclaw/snapshot-sync.json" 2>/dev/null || \
            echo "请手动编辑: ~/.openclaw/snapshot-sync.json"
        ;;
    
    list|ls)
        list_snapshots
        ;;
    
    help|--help|-h)
        show_help
        ;;
    
    version|--version|-v)
        echo "snapshot-sync v${VERSION}"
        ;;
    
    *)
        echo "❌ 未知命令: $COMMAND"
        echo ""
        show_help
        exit 1
        ;;
esac
