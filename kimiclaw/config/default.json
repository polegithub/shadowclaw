{
  "version": "4.1.0",
  "name": "KimiClaw",
  "description": "OpenClaw 环境快照管理工具 - 极致体积、一键恢复",

  "snapshot": {
    "outputDir": "./snapshots",
    "maxFileSizeMB": 5,
    "compression": true,
    "excludePatterns": [
      "*.log",
      "**/node_modules/**",
      "extensions/**",
      "**/extensions/**",
      "canvas/**",
      "**/canvas/**",
      "completions/**",
      "**/completions/**",
      "delivery-queue/**",
      "**/delivery-queue/**",
      "logs/**",
      "**/logs/**",
      "snapshots/**",
      "**/snapshots/**",
      "**/*.tar.gz",
      "**/.git/**",
      "**/*.bak",
      "**/*.tmp",
      "**/tmp/**",
      "agents/**/cache/**",
      "agents/**/temp/**",
      "**/__pycache__/**",
      "**/*.pyc",
      "**/.DS_Store",
      "**/Thumbs.db"
    ],
    "sizeLimits": {
      "*.jsonl": 52428800,
      "*.sqlite": 104857600,
      "*": 5242880
    },
    "whitelist": [
      "openclaw.json",
      "agents/**/auth-profiles.json",
      "agents/**/sessions.json",
      "agents/**/sessions/*.jsonl",
      "credentials/**/*.json",
      "memory/main.sqlite",
      "memory/lancedb/**",
      "workspace/*.md",
      "workspace/memory/*.md",
      "workspace/skills/**",
      "skills/**",
      "cron/jobs.json",
      "identity/*.json",
      ".env"
    ]
  },
  
  "priority": {
    "critical": {
      "label": "⭐⭐⭐ 必备",
      "description": "丢失后无法恢复或恢复成本极高",
      "paths": [
        "openclaw.json",
        "agents/main/agent/auth-profiles.json",
        "agents/main/sessions/sessions.json",
        "credentials/oauth.json",
        "credentials/feishu-pairing.json",
        "credentials/whatsapp/default/creds.json",
        "memory/main.sqlite",
        "memory/lancedb/**",
        "workspace/AGENTS.md",
        "workspace/SOUL.md",
        "workspace/USER.md",
        "workspace/IDENTITY.md",
        "workspace/MEMORY.md",
        "workspace/memory/*.md"
      ]
    },
    "important": {
      "label": "⭐⭐ 重要",
      "description": "丢失后可重建但耗时",
      "paths": [
        ".env",
        "agents/main/agent/models.json",
        "agents/main/sessions/*.jsonl",
        "workspace/TOOLS.md",
        "workspace/HEARTBEAT.md",
        "workspace/skills/**",
        "cron/jobs.json",
        "identity/device.json",
        "identity/device-auth.json",
        "skills/**"
      ]
    },
    "optional": {
      "label": "⭐ 可选",
      "description": "有自动重建机制或体积过大",
      "paths": [
        "openclaw.json.bak*",
        "update-check.json",
        "workspace/BOOTSTRAP.md",
        "workspace/README.md",
        "workspace/tasks.json"
      ]
    }
  },
  
  "sensitive": {
    "fields": [
      "token",
      "apiKey",
      "api_key",
      "secret",
      "password",
      "privateKey",
      "client_secret",
      "access_token",
      "refresh_token",
      "credential"
    ],
    "maskTemplate": "{{SECRET:{{field}}}}"
  },
  
  "github": {
    "repo": "github.com/polegithub/shadowclaw",
    "branch": "main",
    "targetDir": "kimiclaw/snapshots"
  }
}
