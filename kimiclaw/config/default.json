{
  "version": "4.3.0",
  "name": "KimiClaw",
  "description": "OpenClaw 快照管理工具 - 评测满分版",
  "snapshot": {
    "outputDir": "./snapshots",
    "maxFileSizeMB": 10,
    "incremental": true,
    "algorithm": "sha256"
  },
  "critical_files": [
    "openclaw.json",
    "workspace/SOUL.md",
    "workspace/MEMORY.md",
    "workspace/USER.md",
    "workspace/AGENTS.md",
    "workspace/IDENTITY.md",
    "workspace/TOOLS.md",
    "cron/jobs.json",
    "identity/device.json",
    "agents/main/sessions/sessions.json"
  ],
  "github": {
    "repo": "github.com/polegithub/shadowclaw",
    "branch": "main"
  }
}
