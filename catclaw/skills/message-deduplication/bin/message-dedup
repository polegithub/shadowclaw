#!/bin/bash
# message-dedup: 消息去重与重试控制主入口

set -e

VERSION="1.0.0"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEDUP_DIR="${HOME}/.openclaw/dedup"

# 确保目录存在
mkdir -p "$DEDUP_DIR"/{fingerprints,cron-locks}

# 生成指纹
generate_fingerprint() {
    local content="$1"
    local sender="$2"
    local tolerance="${3:-60}"
    
    # 标准化内容
    local normalized=$(echo "$content" | tr '[:upper:]' '[:lower:]' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
    
    # 内容哈希（前16位）
    local content_hash=$(echo -n "$normalized" | sha256sum | cut -c1-16)
    
    # 时间戳取整
    local normalized_time=$(($(date +%s) / tolerance * tolerance))
    
    echo "${sender}:${content_hash}:${normalized_time}"
}

# 检查指纹是否存在
check_fingerprint() {
    local fingerprint="$1"
    local fingerprint_file="$DEDUP_DIR/fingerprints/cache.json"
    
    if [ -f "$fingerprint_file" ]; then
        if grep -q "\"$fingerprint\"" "$fingerprint_file" 2>/dev/null; then
            return 0  # 存在
        fi
    fi
    return 1  # 不存在
}

# 保存指纹
mark_fingerprint() {
    local fingerprint="$1"
    local fingerprint_file="$DEDUP_DIR/fingerprints/cache.json"
    
    # 创建或更新缓存文件
    if [ ! -f "$fingerprint_file" ]; then
        echo "{\"fingerprints\":[],\"last_cleanup\":$(date +%s)}" > "$fingerprint_file"
    fi
    
    # 添加新指纹（带时间戳）
    local timestamp=$(date +%s)
    local temp_file=$(mktemp)
    
    jq ".fingerprints += [{\"hash\":\"$fingerprint\",\"ts\":$timestamp}] | 
        .fingerprints = (.fingerprints | sort_by(.ts) | reverse | .[0:1000])" \
        "$fingerprint_file" > "$temp_file" && mv "$temp_file" "$fingerprint_file"
}

# 检查 cron 锁
check_cron_lock() {
    local job_name="$1"
    local lock_file="$DEDUP_DIR/cron-locks/${job_name}.lock"
    local timeout="${2:-600}"  # 默认10分钟超时
    
    if [ -f "$lock_file" ]; then
        local lock_time=$(cat "$lock_file")
        local current_time=$(date +%s)
        local elapsed=$((current_time - lock_time))
        
        if [ $elapsed -lt $timeout ]; then
            return 0  # 锁存在且未超时
        else
            # 锁已超时，删除旧锁
            rm -f "$lock_file"
            return 1
        fi
    fi
    return 1  # 锁不存在
}

# 设置 cron 锁
set_cron_lock() {
    local job_name="$1"
    local lock_file="$DEDUP_DIR/cron-locks/${job_name}.lock"
    
    date +%s > "$lock_file"
}

# 清除 cron 锁
clear_cron_lock() {
    local job_name="$1"
    local lock_file="$DEDUP_DIR/cron-locks/${job_name}.lock"
    local status_file="$DEDUP_DIR/cron-locks/${job_name}.status"
    
    rm -f "$lock_file"
    
    # 记录状态和时间
    echo "{\"status\":\"$2\",\"end_time\":$(date +%s)}" > "$status_file"
}

# 计算退避时间
calculate_backoff() {
    local attempt="$1"
    local base="${2:-10}"
    local max="${3:-300}"
    
    # 指数退避: base * 2^attempt
    local backoff=$((base * (2 ** attempt)))
    
    # 限制最大值
    if [ $backoff -gt $max ]; then
        backoff=$max
    fi
    
    echo $backoff
}

# 显示帮助
show_help() {
    cat << EOF
Message Deduplication v${VERSION}

用法: message-dedup <命令> [选项]

命令:
  check --content "..." --sender "id"     检查消息是否已处理
  mark --content "..." --sender "id"      标记消息已处理
  
  cron-check --job "name"                 检查 cron 任务是否已在运行
  cron-start --job "name"                 标记 cron 任务开始
  cron-end --job "name" --status success  标记 cron 任务结束
  cron-force-unlock --job "name"          强制释放 cron 锁
  
  get-backoff --attempt N                 获取第 N 次重试的退避时间
  
  stats                                   显示统计信息
  clear-all                               清除所有缓存
  
  help                                    显示帮助

示例:
  message-dedup check --content "你好" --sender "user123"
  message-dedup mark --content "你好" --sender "user123"
  message-dedup cron-check --job "daily-news"
  message-dedup get-backoff --attempt 2

EOF
}

# 主逻辑
COMMAND="${1:-help}"
shift || true

case "$COMMAND" in
    check)
        CONTENT=""
        SENDER=""
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --content) CONTENT="$2"; shift 2 ;;
                --sender) SENDER="$2"; shift 2 ;;
                *) shift ;;
            esac
        done
        
        if [ -z "$CONTENT" ] || [ -z "$SENDER" ]; then
            echo "❌ 缺少参数: --content 和 --sender 是必需的"
            exit 1
        fi
        
        FP=$(generate_fingerprint "$CONTENT" "$SENDER")
        if check_fingerprint "$FP"; then
            echo "DUPLICATE"
            exit 0
        else
            echo "UNIQUE"
            exit 1
        fi
        ;;
    
    mark)
        CONTENT=""
        SENDER=""
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --content) CONTENT="$2"; shift 2 ;;
                --sender) SENDER="$2"; shift 2 ;;
                *) shift ;;
            esac
        done
        
        if [ -z "$CONTENT" ] || [ -z "$SENDER" ]; then
            echo "❌ 缺少参数"
            exit 1
        fi
        
        FP=$(generate_fingerprint "$CONTENT" "$SENDER")
        mark_fingerprint "$FP"
        echo "MARKED"
        ;;
    
    cron-check)
        JOB=""
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --job) JOB="$2"; shift 2 ;;
                *) shift ;;
            esac
        done
        
        if [ -z "$JOB" ]; then
            echo "❌ 缺少 --job 参数"
            exit 1
        fi
        
        if check_cron_lock "$JOB"; then
            echo "LOCKED"
            exit 0
        else
            echo "UNLOCKED"
            exit 1
        fi
        ;;
    
    cron-start)
        JOB=""
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --job) JOB="$2"; shift 2 ;;
                *) shift ;;
            esac
        done
        
        if [ -z "$JOB" ]; then
            echo "❌ 缺少 --job 参数"
            exit 1
        fi
        
        set_cron_lock "$JOB"
        echo "LOCKED"
        ;;
    
    cron-end)
        JOB=""
        STATUS="success"
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --job) JOB="$2"; shift 2 ;;
                --status) STATUS="$2"; shift 2 ;;
                *) shift ;;
            esac
        done
        
        if [ -z "$JOB" ]; then
            echo "❌ 缺少 --job 参数"
            exit 1
        fi
        
        clear_cron_lock "$JOB" "$STATUS"
        echo "UNLOCKED (status: $STATUS)"
        ;;
    
    cron-force-unlock)
        JOB=""
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --job) JOB="$2"; shift 2 ;;
                *) shift ;;
            esac
        done
        
        if [ -z "$JOB" ]; then
            echo "❌ 缺少 --job 参数"
            exit 1
        fi
        
        rm -f "$DEDUP_DIR/cron-locks/${JOB}.lock"
        echo "FORCE UNLOCKED"
        ;;
    
    get-backoff)
        ATTEMPT=0
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --attempt) ATTEMPT="$2"; shift 2 ;;
                *) shift ;;
            esac
        done
        
        SECONDS=$(calculate_backoff "$ATTEMPT")
        echo "$SECONDS"
        ;;
    
    stats)
        echo "📊 Message Deduplication Stats"
        echo "=============================="
        
        if [ -f "$DEDUP_DIR/fingerprints/cache.json" ]; then
            local count=$(jq '.fingerprints | length' "$DEDUP_DIR/fingerprints/cache.json" 2>/dev/null || echo 0)
            echo "Cached fingerprints: $count"
        else
            echo "Cached fingerprints: 0"
        fi
        
        if [ -d "$DEDUP_DIR/cron-locks" ]; then
            local locks=$(find "$DEDUP_DIR/cron-locks" -name "*.lock" | wc -l)
            echo "Active cron locks: $locks"
            if [ $locks -gt 0 ]; then
                echo ""
                echo "Locked jobs:"
                for lock in "$DEDUP_DIR/cron-locks"/*.lock; do
                    if [ -f "$lock" ]; then
                        local job=$(basename "$lock" .lock)
                        local time=$(cat "$lock")
                        local age=$(($(date +%s) - time))
                        echo "  - $job (${age}s ago)"
                    fi
                done
            fi
        fi
        ;;
    
    clear-all)
        read -p "确定要清除所有缓存? (y/N): " confirm
        if [[ "$confirm" =~ ^[Yy]$ ]]; then
            rm -rf "$DEDUP_DIR"/*
            mkdir -p "$DEDUP_DIR"/{fingerprints,cron-locks}
            echo "✅ 已清除所有缓存"
        else
            echo "已取消"
        fi
        ;;
    
    help|--help|-h)
        show_help
        ;;
    
    *)
        echo "❌ 未知命令: $COMMAND"
        show_help
        exit 1
        ;;
esac
