#!/bin/bash
# snapshot-pull: 从远程仓库拉取快照

set -e

REPO_URL="${1:-}"
BRANCH="${2:-main}"
OUTPUT_DIR="${3:-${HOME}/.openclaw/snapshots/pull-$(date +%Y%m%d-%H%M%S)}"

# 读取配置
CONFIG_FILE="${HOME}/.openclaw/snapshot-sync.json"
if [ -f "$CONFIG_FILE" ]; then
    REPO_URL="${REPO_URL:-$(cat "$CONFIG_FILE" | jq -r '.github.repo // empty')}"
    BRANCH="${BRANCH:-$(cat "$CONFIG_FILE" | jq -r '.github.branch // "main"')}"
fi

# 检查仓库地址
if [ -z "$REPO_URL" ]; then
    echo "❌ 错误: 未指定仓库地址"
    echo ""
    echo "用法: snapshot-pull [仓库地址] [分支] [输出目录]"
    echo ""
    echo "或在 ~/.openclaw/snapshot-sync.json 中配置:"
    echo '{'
    echo '  "github": {'
    echo '    "repo": "github.com/username/repo",'
    echo '    "branch": "main"'
    echo '  }'
    echo '}'
    exit 1
fi

# 处理仓库 URL
if [[ "$REPO_URL" == github.com/* ]]; then
    REMOTE_URL="https://github.com/${REPO_URL#github.com/}.git"
    REPO_DISPLAY="$REPO_URL"
elif [[ "$REPO_URL" == http* ]]; then
    REMOTE_URL="$REPO_URL"
    REPO_DISPLAY="$REPO_URL"
else
    REMOTE_URL="https://github.com/${REPO_URL}.git"
    REPO_DISPLAY="github.com/${REPO_URL}"
fi

echo "📥 拉取快照"
echo "=========="
echo "仓库: $REPO_DISPLAY"
echo "分支: $BRANCH"
echo "输出: $OUTPUT_DIR"
echo ""

# 创建输出目录
mkdir -p "$OUTPUT_DIR"

# 克隆仓库
echo "🔄 正在克隆..."
if git clone --depth 1 --branch "$BRANCH" "$REMOTE_URL" "$OUTPUT_DIR" 2>&1; then
    echo "✓ 克隆完成"
else
    echo ""
    echo "❌ 拉取失败"
    echo ""
    echo "可能的原因："
    echo "   • 仓库不存在或没有访问权限"
    echo "   • 分支不存在"
    echo "   • 网络问题"
    exit 1
fi

# 移除 .git 目录以节省空间
rm -rf "$OUTPUT_DIR/.git"

# 验证快照完整性
echo ""
echo "🔍 验证快照..."

if [ ! -f "$OUTPUT_DIR/manifest.json" ]; then
    echo "⚠️ 警告: 未找到 manifest.json，这可能不是一个标准的 OpenClaw 快照"
else
    echo "✓ 找到 manifest.json"
    
    # 显示快照信息
    echo ""
    echo "📊 快照信息:"
    jq -r '
        "   生成时间: \(.generated_at // "unknown")",
        "   Skills: \(.stats.skills_count // 0)",
        "   记忆文件: \(.stats.memory_files // 0)",
        "   工作区文件: \(.stats.workspace_files // 0)",
        "   总大小: \(.stats.total_size_mb // 0) MB",
        "   排除文件: \(.stats.excluded_files_count // 0)"
    ' "$OUTPUT_DIR/manifest.json" 2>/dev/null || echo "   (无法解析 manifest)"
fi

echo ""
echo "✅ 拉取完成！"
echo ""
echo "📂 快照位置: $OUTPUT_DIR"
echo ""
echo "下一步:"
echo "   • 预览内容: ls -la $OUTPUT_DIR"
echo "   • 恢复环境: snapshot-sync restore $OUTPUT_DIR"
echo "   • 查看说明: cat $OUTPUT_DIR/README.md"
